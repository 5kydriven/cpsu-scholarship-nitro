# ─────────────────────────────────────────────
# CPSU Scholarship — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database ─────────────────────────────────
# ⚠️  Use the DIRECT connection (port 5432), NOT the pooler.
#     Pooler URL breaks Drizzle migrations.
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Mail (SMTP) ───────────────────────────────
# Used for: application approved/rejected emails (Phase 3)
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-smtp-password
MAIL_FROM=no-reply@cpsu-scholarship.edu.ph

# ── Supabase Storage ─────────────────────────
# Bucket for uploaded application documents (disability cert, IP group cert)
# Create this bucket in your Supabase dashboard before Phase 3.
STORAGE_BUCKET_DOCUMENTS=application-documents

# ── Export ───────────────────────────────────
# Appears as header on PDF/Excel exports of approved scholars (Phase 5)
EXPORT_HEADER_TITLE=Central Philippine State University
EXPORT_HEADER_SUBTITLE=Scholarship Management System

# ── AI — Claude API (Phase 6) ─────────────────
# Optional until Phase 6. Server starts without it but AI selection is disabled.
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=
